# Steward agent — environment template. Copy to `.env` (gitignored) and fill real values.
# Real secrets live ONLY in .env, never committed. .gitignore covers .env, secrets/, *.pem.

# ── Casper testnet (Casper 2.0 "Condor") — verified live 2026-06-25 ──────────
CASPER_NODE_RPC=https://node.testnet.casper.network/rpc
CASPER_NETWORK_NAME=casper-test
AGENT_SECRET_KEY_PATH=./secrets/secret_key.pem
# Node sidecar (casper-js-sdk v5) the Python chain layer shells out to:
STEWARD_SIDECAR=agent/sidecar/chain.mjs
# Reference only (no programmatic API; funding is wallet-gated):
CASPER_FAUCET_URL=https://testnet.cspr.live/tools/faucet
CASPER_EXPLORER_URL=https://testnet.cspr.live

# ── LLM: Anthropic (Phase 3 — reuse your prior-build key; real value only in .env) ──
ANTHROPIC_API_KEY=
STEWARD_MODEL=claude-opus-4-8

# ── IPFS: Pinata V3 (Phase 3) ───────────────────────────────────────────────
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# ── Loop config (Phase 3) ───────────────────────────────────────────────────
CYCLE_SECONDS=900
