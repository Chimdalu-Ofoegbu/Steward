# Steward frontend — read-only Casper testnet config (no secrets required).
# Copy to .env.local. All reads are server-side via casper-js-sdk v5.

# Casper testnet RPC endpoint (same node the agent sidecar uses).
CASPER_NODE_RPC=https://node.testnet.casper.network/rpc
CASPER_NETWORK_NAME=casper-test

# The agent's ed25519 public key (treasury owner) — from deployments/testnet.json.
AGENT_PUBLIC_KEY_HEX=01c85dcb19012ff343ef214d34ad00c9fe38ee3b3abbffdfff276de121cc87539e

# Deployed Journal contract package hash (hex, no prefix) — from deployments/testnet.json.
JOURNAL_PACKAGE_HASH=506497e9dc4607460891120b7bccc8b182686ab2207a629cbb57204d5bab3aa2

# IPFS gateway used to fetch pinned decision payloads (RAW bytes for verification).
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# Block explorer base (testnet).
EXPLORER=https://testnet.cspr.live
